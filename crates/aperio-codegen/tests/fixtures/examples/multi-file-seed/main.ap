// Per-directory seed model. Every .ap file in this directory
// contributes to one bundle; top-level decls in any file are
// visible to every other file.
//
// Build with the directory as the target:
//   aperio build examples/51-multi-file-app
//   ./examples/51-multi-file-app/51-multi-file-app
//
// File order is alphabetical: greet.ap then main.ap. Order
// doesn't matter for resolution — the bundle flattens all
// top-level decls into one shared scope.

locus AppL {
    params {
        who: String = "world";
    }
    run() {
        let phrase = greeting(self.who);
        say(phrase);
    }
}

fn main() {
    AppL { };
}
