// Sum types and exhaustive match. Remove a case from `next` and the
// program refuses to compile — a match must cover every variant.
type Light = enum { Red, Yellow, Green };

fn next(l: Light) -> Light {
    let mut out = Light::Red;
    match l {
        Light::Red -> { out = Light::Green; },
        Light::Green -> { out = Light::Yellow; },
        Light::Yellow -> { out = Light::Red; },
    }
    return out;
}

fn main() {
    let mut l = Light::Red;
    let mut step = 0;
    while step < 5 {
        println("light: ", l);
        l = next(l);
        step = step + 1;
    }
}
