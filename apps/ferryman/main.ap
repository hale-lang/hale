// ferryman — the codebase-recognition ferry.
//
// **Carries you across the boundary.** Ferryman takes you
// across the river between unfamiliar source code and seen-
// as-locus-tower. It is the standard interface for recognizing
// existing codebases — point it at a repo root, get one
// polished recognition report per binary entrypoint discovered
// underneath.
//
// **Multi-binary aware.** Unlike onboard (which assumes the
// input dir IS the binary), ferryman walks the tree looking
// for every `main.go` (Go v0; generalizes per Lang flavor
// later) and runs the recognition pipeline once per discovered
// binary. Pointing it at a Cobra-CLI monorepo surfaces every
// binary; pointing it at a single-binary dir behaves like
// onboard did. The user doesn't have to know which subdirs
// contain mains.
//
// **The polished middle-step product.** The first deliverable
// of the codebase-onboarder arc is a perception tool, not a
// transpiler: a developer (or LLM agent driving a session)
// points ferryman at a foreign codebase, gets a structured
// recognition report, and sees the lotus shape already
// present in the source. Per
// `notes/codebase-onboarding-design.md`.
//
// **Agent-friendly.** Unknowns are flagged prominently with
// file paths and shape-rule hints; an LLM driving the session
// reads the report, opens the flagged files, and writes
// resolutions to `.aperio-overrides` at the repo root. Per
// `notes/onboarding-shape-rules.md`.
//
// Per the apps-are-loci ethos, wrapped in `FerrymanL`.
//
// Usage:
//   aperio build apps/ferryman/main.ap
//   apps/ferryman/main [REPO_ROOT] [LANG_FLAVOR]
//
// The three-step ritual in main() — instantiate Resolver,
// collapse FerrymanConfig, hand to FerrymanL — is the
// exemplary Aperio composition: locus (resolution flow), type
// (shape contract), locus (app run). Tests bypass the Resolver
// by constructing FerrymanConfig directly.

// Shape contract — every helper takes this Config instead of
// loose params, so adding fields (binary filter, tower mode,
// max recursion depth, etc.) doesn't ripple through signatures.
type FerrymanConfig {
    dir: String;
    flavor: String;
}

// ---- Per-file unified walk (shared shape with tower-join). ----

// Walks an AST subtree producing a tagged-string accumulator.
// `caller` carries the name of the enclosing fn so each
// `call_expression` we hit emits `CALL:<caller>:<callee>` —
// the raw data the entrypoint-mode outward walker traverses.
// Top-level invocations pass caller="" (calls outside any fn
// body are dropped — they don't have an enclosing locus).
fn __unified_walk(lang: std::lang::Lang, node: Int, in_import: Bool,
                  caller: String) -> String {
    if node == 0 { return ""; }
    let mut acc = "";
    if lang.is_package_clause(node) {
        acc = acc + "PKG:" + lang.extract_package_name(node) + "\n";
    }
    let mut now_in_import = in_import;
    if lang.is_import_decl(node) { now_in_import = true; }
    if now_in_import && lang.is_string_literal(node) {
        let raw = std::ts::node_text(node);
        acc = acc + "IMP:" + lang.strip_string_quotes(raw) + "\n";
    }
    // Update the caller context when we enter a fn-decl. Calls
    // inside this fn's body recurse with the new caller; calls
    // at top-level (caller == "") are dropped.
    let mut now_caller = caller;
    if lang.is_fn_decl(node) {
        // Always record the fn-def name so cross-file lookups
        // (goroutine target resolution, outward call tree) can
        // find which file defines a given fn.
        acc = acc + "FN_DEF:" + lang.extract_fn_name(node) + "\n";
        if lang.is_main_fn(node) {
            acc = acc + "OP_MAIN:1\n";
        } else if lang.is_init_fn(node) {
            acc = acc + "OP_INIT:1\n";
        } else if lang.is_http_handler(node) {
            acc = acc + "OP_HANDLER:" + lang.extract_fn_name(node) + "\n";
        }
        now_caller = lang.extract_fn_name(node);
    }
    if lang.is_concurrent_spawn(node) {
        let kind = lang.spawn_kind(node);
        let target = lang.extract_spawn_target(node);
        // Encode kind + target together: "named:backgroundWorker"
        // or "anonymous:". Empty target is the anonymous case
        // (or an unsupported call shape we couldn't resolve).
        acc = acc + "OP_SPAWN:" + kind + ":" + target + "\n";
    }
    if lang.is_infinite_loop(node) {
        acc = acc + "OP_LOOP:1\n";
    }
    if lang.is_type_spec(node) {
        acc = acc + "TYPE:" + lang.extract_type_name(node) + "\n";
    }
    // Handler wiring: `mux.HandleFunc("/path", h)` records
    // both the route + target so the operational summary can
    // show handlers with their bus-subject equivalent (the
    // Aperio shape: HTTP route → bus subject).
    if lang.is_handler_registration(node) {
        let route = lang.extract_handler_route(node);
        let target = lang.extract_handler_target(node);
        if len(route) > 0 && len(target) > 0 {
            acc = acc + "WIRE:" + target + "->" + route + "\n";
        }
    }
    // Outward-tower seed: every call inside a fn body emits a
    // CALL row. Handler registrations also match — we already
    // captured them via WIRE above, so skip the CALL emission
    // to avoid double-counting (the WIRE row carries the same
    // edge with richer context).
    if lang.is_call_expression(node) && len(now_caller) > 0
            && !lang.is_handler_registration(node) {
        let callee = lang.extract_call_name(node);
        if len(callee) > 0 {
            acc = acc + "CALL:" + now_caller + ":" + callee + "\n";
        }
    }
    let n = std::ts::node_named_child_count(node);
    let mut i = 0;
    while i < n {
        let c = std::ts::node_named_child(node, i);
        acc = acc + __unified_walk(lang, c, now_in_import, now_caller);
        i = i + 1;
    }
    return acc;
}

// __count_tag / __first_tag_body / __collect_tag_csv lifted to
// std::tagged::Accumulator. __propose_locus_name lifted to
// std::name::Convention. __ends_with_source superseded by the
// std::io::fs::extension primitive. The render path below uses
// `ta`, `nc`, and `std::io::fs::extension` directly.

// ---- Aperio-shape narrative inference. ----
//
// Given a file's per-tower signal, infer a short description of
// the locus shape it would land as in absorbed Aperio source.
// v0 covers the patterns the operational extractor recognizes.
fn __infer_locus_shape(has_main: Bool, has_init: Bool, n_handlers: Int,
                       n_spawns: Int, n_loops: Int, n_types: Int,
                       n_imports: Int) -> String {
    if has_main {
        if n_spawns > 0 || n_handlers > 0 {
            return "root locus — birth() = init code, run() = main body, "
                + "child loci = spawned goroutines / handler subscribers";
        }
        return "root locus — run() = main body";
    }
    if n_handlers > 0 {
        return "bus-subscriber locus — each handler is a subscriber on a "
            + "path-derived subject (HTTP route → bus subject)";
    }
    if n_loops > 0 {
        return "long-running child locus — run() = the infinite loop body, "
            + "dissolve() = parent-driven termination";
    }
    if n_spawns > 0 {
        return "concurrent-spawning locus — child loci spawned in run()";
    }
    if n_types > 0 {
        if n_imports > 0 {
            return "state-holding sibling locus — typed fields hold the "
                + "shared state other loci coordinate around";
        }
        return "shape-only file — no flow signal; types likely emit as "
            + "`type` declarations rather than loci";
    }
    if n_imports > 0 {
        return "structural support — imports without types or flow; likely "
            + "free fns and constants the other loci depend on";
    }
    return "structural artifact — empty or pure boilerplate";
}

// ---- Per-file report rendering. ----

fn __indent_block(label: String, content: String) -> String {
    if len(content) == 0 {
        return "  " + label + "  (none)\n";
    }
    return "  " + label + "  " + content + "\n";
}

// Look up which file defines a given fn name. `fn_defs` is a
// cross-file aggregate of "FN_DEF:<name>:<file>\n" lines built
// in the first pass of __drive. Returns "" if the fn isn't
// defined in any scanned file (e.g., it's a stdlib call or
// imported from another package).
fn __lookup_fn_file(fn_defs: String, name: String) -> String {
    let total = len(fn_defs);
    let mut from = 0;
    let needle = "FN_DEF:" + name + ":";
    let nlen = len(needle);
    while from < total {
        let rest = fn_defs[from..total];
        let nl = std::str::index_of(rest, "\n");
        let mut line = "";
        if nl < 0 { line = rest; from = total; }
        else { line = rest[0..nl]; from = from + nl + 1; }
        if len(line) > nlen {
            if line[0..nlen] == needle {
                return line[nlen..len(line)];
            }
        }
    }
    return "";
}

// Look up a handler fn's route in a "WIRE:target->route\n"-
// formatted aggregate string. Returns "" if the target hasn't
// been wired in this codebase (the handler is defined but not
// registered, or the registration uses an unrecognized router).
fn __lookup_handler_route(wires: String, target: String) -> String {
    let total = len(wires);
    let mut from = 0;
    let needle = "WIRE:" + target + "->";
    let nlen = len(needle);
    while from < total {
        let rest = wires[from..total];
        let nl = std::str::index_of(rest, "\n");
        let mut line = "";
        if nl < 0 { line = rest; from = total; }
        else { line = rest[0..nl]; from = from + nl + 1; }
        if len(line) > nlen {
            if line[0..nlen] == needle {
                return line[nlen..len(line)];
            }
        }
    }
    return "";
}

// ---- Entrypoint-mode (outward tower). ----
//
// `calls` is the aggregated CALL:<caller>:<callee> rows from
// every file in the scanned dir. The outward walker starts at
// main(), enumerates main's direct callees, and recurses into
// each one whose name resolves through FN_DEF (i.e., is
// defined within the scanned scope). Stdlib / external /
// method-call leaves render but don't recurse.

// Return the newline-separated list of callees of `caller`,
// in the order they appear in `calls`. Duplicates preserved —
// a fn calling the same target twice shows twice.
fn __callees_of(calls: String, caller: String) -> String {
    let it = std::iter::Lines { };
    let needle = "CALL:" + caller + ":";
    let nlen = len(needle);
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(calls, from);
        from = it.next_idx(calls, from);
        if len(line) <= nlen { continue; }
        if line[0..nlen] != needle { continue; }
        let callee = line[nlen..len(line)];
        if len(callee) == 0 { continue; }
        out = out + callee + "\n";
    }
    return out;
}

// True if `name` already appears on a single line of the
// visited-set String (lines separated by "\n"). Used to break
// recursion cycles when the outward walker encounters a fn
// that's already an ancestor in the current branch.
fn __visited_contains(visited: String, name: String) -> Bool {
    let it = std::iter::Lines { };
    let mut from = 0;
    while from >= 0 {
        let v = it.line_at(visited, from);
        from = it.next_idx(visited, from);
        if v == name { return true; }
    }
    return false;
}

// Build the indent prefix for tree-depth `d`. Each level is
// 4 spaces; opens with "│   " on intermediate levels so the
// vertical guide renders cleanly. Depth 0 has no indent.
fn __tree_indent(d: Int) -> String {
    let mut out = "";
    let mut i = 0;
    while i < d {
        out = out + "│   ";
        i = i + 1;
    }
    return out;
}

// Render one outward-tower row at depth `d`. `callee` is the
// fn name, `where_at` is its file (or a {marker} for leaves
// — `{stdlib}`, `{external}`, `{method}`). `motion` is the
// domain-lens motion-form attached by the morpheme rewriter.
fn __render_call_row(d: Int, callee: String, where_at: String,
                     motion: String) -> String {
    let indent = __tree_indent(d);
    if len(motion) == 0 {
        return indent + "├─ " + callee + "  " + where_at + "\n";
    }
    return indent + "├─ " + callee + "  " + where_at
        + "  · " + motion + "\n";
}

// Recursive outward walk. Returns the tree text rooted at
// `caller`. Cycles broken via `visited`; overall depth capped
// at `max_depth` so a tangled program can't blow the output.
// Cross-dir walk callback. The Walk seed hands us each
// parsed file; we emit a tagged-string fragment with the
// bare file name attached to the rows the outward + inward
// towers need (IMP_FILE, FN_DEF, OP_MAIN). WIRE and CALL
// pass through unchanged — they don't need file context.
// Other __unified_walk rows (PKG, TYPE, OP_INIT, OP_HANDLER,
// OP_SPAWN, OP_LOOP) are dropped here; the per-file
// rendering pass picks them up separately when it re-parses.
//
// The fn-pointer signature can't carry a `file_prefix`
// (fn-pointers can't capture state at v0); the user-dir walk
// emits bare names and the sibling-dir walks go through
// __prefix_stamp afterwards to add the relative-path prefix.
fn __cross_dir_callback(lang: std::lang::Lang, name: String,
                        root: Int) -> String {
    let walk = __unified_walk(lang, root, false, "");
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(walk, from);
        from = it.next_idx(walk, from);
        if len(line) == 0 { continue; }
        if len(line) > 4 {
            if line[0..4] == "IMP:" {
                let imp = line[4..len(line)];
                out = out + "IMP_FILE:" + name + ":" + imp + "\n";
                continue;
            }
        }
        if len(line) > 5 {
            if line[0..5] == "WIRE:" { out = out + line + "\n"; continue; }
            if line[0..5] == "CALL:" { out = out + line + "\n"; continue; }
        }
        if len(line) > 7 {
            if line[0..7] == "FN_DEF:" {
                let fname = line[7..len(line)];
                out = out + "FN_DEF:" + fname + ":" + name + "\n";
                continue;
            }
        }
        if len(line) >= 8 {
            if line[0..8] == "OP_MAIN:" {
                out = out + "OP_MAIN:" + name + "\n";
                continue;
            }
        }
    }
    return out;
}

// Sibling-dir prefix-stamping. Walks the cross-dir callback's
// output and prepends `prefix` to the file portion of each
// IMP_FILE / FN_DEF / OP_MAIN row, leaving WIRE / CALL rows
// unchanged. Called once per sibling-dir walk so the outward
// tower's file lookups resolve like "cmd/setup.go" instead of
// colliding with a user-dir "setup.go".
fn __prefix_stamp(rows: String, prefix: String) -> String {
    if len(prefix) == 0 { return rows; }
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(rows, from);
        from = it.next_idx(rows, from);
        if len(line) == 0 { continue; }
        if len(line) > 9 {
            if line[0..9] == "IMP_FILE:" {
                let body = line[9..len(line)];
                let colon = std::str::index_of(body, ":");
                if colon < 0 { out = out + line + "\n"; continue; }
                let file = body[0..colon];
                let rest = body[colon..len(body)];
                out = out + "IMP_FILE:" + prefix + file + rest + "\n";
                continue;
            }
        }
        if len(line) > 7 {
            if line[0..7] == "FN_DEF:" {
                let body = line[7..len(line)];
                let colon = std::str::index_of(body, ":");
                if colon < 0 { out = out + line + "\n"; continue; }
                let fname = body[0..colon];
                let file = body[colon+1..len(body)];
                out = out + "FN_DEF:" + fname + ":" + prefix + file + "\n";
                continue;
            }
        }
        if len(line) >= 8 {
            if line[0..8] == "OP_MAIN:" {
                let file = line[8..len(line)];
                out = out + "OP_MAIN:" + prefix + file + "\n";
                continue;
            }
        }
        out = out + line + "\n";
    }
    return out;
}

// Pull the unique set of local-import paths from a walked
// dir's tagged accumulator. Used by __drive to discover which
// sibling dirs to also walk for the cross-dir FN_DEF index.
fn __collect_local_imports(walked: String,
                           module_name: String) -> String {
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(walked, from);
        from = it.next_idx(walked, from);
        if len(line) <= 9 { continue; }
        if line[0..9] != "IMP_FILE:" { continue; }
        // IMP_FILE:<file>:<imp> — strip the leading "IMP_FILE:"
        // and find the colon between file and imp.
        let body = line[9..len(line)];
        let colon = std::str::index_of(body, ":");
        if colon < 0 { continue; }
        let imp = body[colon+1..len(body)];
        if !__is_local_import(imp, module_name) { continue; }
        // Dedupe.
        let needle = imp + "\n";
        let hay = "\n" + out;
        if std::str::index_of(hay, "\n" + needle) >= 0 { continue; }
        out = out + needle;
    }
    return out;
}

fn __walk_outward(calls: String, fn_defs: String,
                  caller: String, visited: String, depth: Int,
                  max_depth: Int, r: std::lang::Morpheme) -> String {
    if depth > max_depth { return ""; }
    let new_visited = visited + caller + "\n";
    let callees = __callees_of(calls, caller);
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let callee = it.line_at(callees, from);
        from = it.next_idx(callees, from);
        if len(callee) == 0 { continue; }
        let callee_file = __lookup_fn_file(fn_defs, callee);
        let motion = r.name_to_motion(callee);
        if len(callee_file) == 0 {
            // Out-of-scope leaf — stdlib call, imported pkg
            // call, or a method-call we couldn't resolve.
            // Render but don't recurse.
            out = out + __render_call_row(depth, callee,
                                          "{external}", motion);
        } else {
            out = out + __render_call_row(depth, callee,
                                          "(" + callee_file + ")",
                                          motion);
            // Cycle break — already in current branch's ancestry.
            if !__visited_contains(new_visited, callee) {
                out = out + __walk_outward(calls, fn_defs, callee,
                                           new_visited, depth + 1,
                                           max_depth, r);
            }
        }
    }
    return out;
}

// Render the outward tower header + body. Empty when the
// scanned dir has no entrypoint (main_file == "").
fn __render_outward_tower(calls: String, fn_defs: String,
                          main_file: String,
                          r: std::lang::Morpheme) -> String {
    if len(main_file) == 0 { return ""; }
    let mut out = "Outward tower — what main() does at runtime\n";
    out = out + "-------------------------------------------\n";
    out = out + "\n";
    let motion = r.name_to_motion("main");
    out = out + "main()  (" + main_file + ")  · " + motion + "\n";
    out = out + __walk_outward(calls, fn_defs, "main", "",
                               0, 4, r);
    out = out + "\n";
    return out;
}

// ---- Entrypoint-mode (inward tower). ----
//
// The inward tower walks the same call structure as the
// outward one, but at file granularity, showing what each
// reachable file depends on. The recognition: outward says
// "what main does"; inward says "what main needs before it
// can do anything." Same fulcrum, two orientations.

// Recursively collect every in-package file reachable from
// `caller` via the call graph. Returns a newline-separated
// list of file names, each appearing at most once (in first-
// reach order).
fn __reachable_files(calls: String, fn_defs: String,
                     caller: String, visited: String,
                     files_so_far: String) -> String {
    let new_visited = visited + caller + "\n";
    let callees = __callees_of(calls, caller);
    let it = std::iter::Lines { };
    let mut files = files_so_far;
    let mut from = 0;
    while from >= 0 {
        let callee = it.line_at(callees, from);
        from = it.next_idx(callees, from);
        if len(callee) == 0 { continue; }
        if __visited_contains(new_visited, callee) { continue; }
        let callee_file = __lookup_fn_file(fn_defs, callee);
        if len(callee_file) == 0 { continue; }
        if !__visited_contains(files, callee_file) {
            files = files + callee_file + "\n";
        }
        files = __reachable_files(calls, fn_defs, callee,
                                  new_visited, files);
    }
    return files;
}

// Return the newline-separated list of imports declared in
// `file`, in source order. Walks the `imports_by_file`
// aggregate (IMP_FILE:<file>:<import> rows).
fn __imports_of(imports_by_file: String, file: String) -> String {
    let it = std::iter::Lines { };
    let needle = "IMP_FILE:" + file + ":";
    let nlen = len(needle);
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(imports_by_file, from);
        from = it.next_idx(imports_by_file, from);
        if len(line) <= nlen { continue; }
        if line[0..nlen] != needle { continue; }
        let imp = line[nlen..len(line)];
        out = out + imp + "\n";
    }
    return out;
}

// ---- Cross-dir traversal helpers. ----
//
// Real-world Go binaries usually have a thin cmd/X/main.go
// that imports application loci from sibling dirs
// (cmd/X imports module/src/foo, module/src/bar). To make the
// outward tower cross those boundaries we resolve the module
// name from go.mod, then walk local-import dirs into the same
// FN_DEF aggregate the single-dir walker populates.

// Index of the last '/' in `s`, or -1 if none.
fn __last_slash_idx(s: String) -> Int {
    let n = len(s);
    let mut i = n - 1;
    while i >= 0 {
        if s[i..i+1] == "/" { return i; }
        i = i - 1;
    }
    return -1;
}

// Return the parent directory of `d` (strip the last "/<seg>").
// Returns "" when there is no parent ("/" or "foo").
fn __parent_dir(d: String) -> String {
    let idx = __last_slash_idx(d);
    if idx <= 0 { return ""; }
    return d[0..idx];
}

// Walk up from `start_dir` looking for a go.mod file. Returns
// the directory containing go.mod (the module root) on hit, or
// "" if none found within 10 ancestor steps. The 10-step cap
// bounds the search on degenerate filesystems and matches the
// conventional Go-tooling expectation that go.mod sits within
// a handful of levels of the source file.
fn __find_module_root(start_dir: String) -> String {
    let mut d = start_dir;
    let mut hops = 0;
    while hops < 10 {
        let probe = d + "/go.mod";
        if std::io::fs::file_exists(probe) { return d; }
        let parent = __parent_dir(d);
        if len(parent) == 0 { return ""; }
        d = parent;
        hops = hops + 1;
    }
    return "";
}

// Pull the module name from `module X` line in go.mod text.
// Returns "" if no module line is found.
fn __extract_module_name(go_mod_text: String) -> String {
    let it = std::iter::Lines { };
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(go_mod_text, from);
        from = it.next_idx(go_mod_text, from);
        if len(line) < 7 { continue; }
        if line[0..7] != "module " { continue; }
        let rest = line[7..len(line)];
        // Tolerate trailing whitespace by trimming a CR if any.
        let n = len(rest);
        if n > 0 {
            if rest[n-1..n] == "\r" { return rest[0..n-1]; }
        }
        return rest;
    }
    return "";
}

// True if `imp` is an import path that resolves to this
// module's own source (the part of the import graph we can
// follow at v0). Either `imp == module_name` exactly (the
// module's root package) or it begins with `<module_name>/`.
fn __is_local_import(imp: String, module_name: String) -> Bool {
    let ml = len(module_name);
    if ml == 0 { return false; }
    let il = len(imp);
    if il < ml { return false; }
    if imp[0..ml] != module_name { return false; }
    if il == ml { return true; }
    return imp[ml..ml+1] == "/";
}

// Convert a local import path into its filesystem directory.
// `grease/cmd` → `<module_root>/cmd`. The exact-module case
// (`grease`) → `<module_root>`.
fn __local_import_to_dir(module_root: String,
                         module_name: String,
                         imp: String) -> String {
    let ml = len(module_name);
    let il = len(imp);
    if il == ml { return module_root; }
    // Drop the "<module_name>/" prefix, prepend module_root.
    return module_root + "/" + imp[ml+1..il];
}

// Classify an import path so the rendering can group them.
//   "stdlib"   — single-segment paths ("log", "fmt") and
//                multi-segment stdlib namespaces
//                ("net/http", "log/slog", "encoding/json").
//                Heuristic: no dot in the first segment AND
//                not a recognized local-module path.
//   "external" — paths whose first segment contains a dot
//                ("github.com/...", "gopkg.in/...").
//   "local"    — paths under the module declared in go.mod.
fn __classify_import(imp: String, module_name: String) -> String {
    if __is_local_import(imp, module_name) { return "local"; }
    let slash = std::str::index_of(imp, "/");
    let head = "";
    let mut h = head;
    if slash < 0 { h = imp; } else { h = imp[0..slash]; }
    if std::str::index_of(h, ".") >= 0 { return "external"; }
    return "stdlib";
}

// Render the imports block for one file inside the inward
// tower. Each import gets its classification suffix so the
// reader can see at a glance whether main's needs are mostly
// stdlib (self-contained) or external (dependency-heavy).
fn __render_file_imports(imports_by_file: String,
                         file: String,
                         module_name: String) -> String {
    let imps = __imports_of(imports_by_file, file);
    if len(imps) == 0 {
        return "    (no imports)\n";
    }
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let imp = it.line_at(imps, from);
        from = it.next_idx(imps, from);
        if len(imp) == 0 { continue; }
        let kind = __classify_import(imp, module_name);
        out = out + "    ├─ " + imp + "  {" + kind + "}\n";
    }
    return out;
}

// Pull every WIRE:<target>-><route> target's defining file
// into a newline-separated list. Routed handlers are reached
// from main via HTTP routing rather than direct call, but
// they're part of what the package needs at runtime — so the
// inward tower's reachable-file seed pulls them in.
fn __wire_target_files(wires: String, fn_defs: String) -> String {
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let line = it.line_at(wires, from);
        from = it.next_idx(wires, from);
        if len(line) <= 5 { continue; }
        if line[0..5] != "WIRE:" { continue; }
        let body = line[5..len(line)];
        let arrow = std::str::index_of(body, "->");
        if arrow < 0 { continue; }
        let target = body[0..arrow];
        let file = __lookup_fn_file(fn_defs, target);
        if len(file) == 0 { continue; }
        if !__visited_contains(out, file) {
            out = out + file + "\n";
        }
    }
    return out;
}

// Walk the inward tower: main's file first, then every file
// reachable from main via the call graph (and via HTTP-route
// wiring), each block listing that file's imports. Files
// dedupe in first-reach order.
fn __render_inward_tower(calls: String, fn_defs: String,
                         wires: String,
                         imports_by_file: String,
                         main_file: String,
                         module_name: String) -> String {
    if len(main_file) == 0 { return ""; }
    let mut out = "Inward tower — what main()'s package needs\n";
    out = out + "------------------------------------------\n";
    out = out + "\n";
    // Seed with main's file + every WIRE target's file so
    // route-only handlers also surface as needed-by-main.
    let mut seed_files = main_file + "\n";
    let wire_files = __wire_target_files(wires, fn_defs);
    let it_w = std::iter::Lines { };
    let mut wfrom = 0;
    while wfrom >= 0 {
        let wf = it_w.line_at(wire_files, wfrom);
        wfrom = it_w.next_idx(wire_files, wfrom);
        if len(wf) == 0 { continue; }
        if !__visited_contains(seed_files, wf) {
            seed_files = seed_files + wf + "\n";
        }
    }
    let files = __reachable_files(calls, fn_defs, "main",
                                  "", seed_files);
    let it = std::iter::Lines { };
    let mut from = 0;
    while from >= 0 {
        let file = it.line_at(files, from);
        from = it.next_idx(files, from);
        if len(file) == 0 { continue; }
        out = out + file + "\n";
        out = out + __render_file_imports(imports_by_file, file,
                                          module_name);
    }
    out = out + "\n";
    return out;
}

fn __render_per_file(lang: std::lang::Lang, r: std::lang::Morpheme,
                     dir: String, name: String, wires: String,
                     fn_defs: String) -> String {
    let path = dir + "/" + name;
    let src = std::io::fs::read_file(path);
    if len(src) == 0 { return ""; }
    let tree = lang.parse(src);
    if tree == 0 { return ""; }
    let root = std::ts::root_node(tree);
    let acc = __unified_walk(lang, root, false, "");

    let ta = std::tagged::Accumulator { };
    let pkg = ta.first_body(acc, "PKG");
    let imports = ta.collect_csv(acc, "IMP");
    let handlers = ta.collect_csv(acc, "OP_HANDLER");
    let spawns = ta.collect_csv(acc, "OP_SPAWN");
    let has_main = ta.count(acc, "OP_MAIN") > 0;
    let has_init = ta.count(acc, "OP_INIT") > 0;
    let n_handlers = ta.count(acc, "OP_HANDLER");
    let n_spawns = ta.count(acc, "OP_SPAWN");
    let n_loops = ta.count(acc, "OP_LOOP");
    let n_imports = ta.count(acc, "IMP");
    let n_types = ta.count(acc, "TYPE");

    let has_op = has_main || has_init || n_handlers > 0
                 || n_spawns > 0 || n_loops > 0;
    let has_harm = n_imports > 0;
    let has_dom = n_types > 0;

    let mut agreement = 0;
    if has_op   { agreement = agreement + 1; }
    if has_harm { agreement = agreement + 1; }
    if has_dom  { agreement = agreement + 1; }

    let mut verdict = "structural";
    if agreement >= 2 { verdict = "locus"; }
    else if agreement == 1 { verdict = "type_or_fn"; }

    let nc = std::name::Convention { strip: ".go" };
    let proposed = nc.propose_locus_name(name);

    // Operational summary line.
    let mut op_summary = "";
    if has_main { op_summary = op_summary + "main() entrypoint"; }
    if has_init {
        if len(op_summary) > 0 { op_summary = op_summary + "; "; }
        op_summary = op_summary + "init() lifecycle hook";
    }
    if n_handlers > 0 {
        if len(op_summary) > 0 { op_summary = op_summary + "; "; }
        // Build a comma-separated handler list with each
        // handler's route in parens if known. Without a known
        // route, just show the name (the wiring may live in
        // a file we haven't scanned, or use an unrecognized
        // router idiom).
        let mut handlers_with_routes = "";
        let prefix = "OP_HANDLER:";
        let plen = len(prefix);
        let mut afrom = 0;
        let atotal = len(acc);
        let mut afirst = true;
        while afrom < atotal {
            let arest = acc[afrom..atotal];
            let anl = std::str::index_of(arest, "\n");
            let mut aline = "";
            if anl < 0 { aline = arest; afrom = atotal; }
            else { aline = arest[0..anl]; afrom = afrom + anl + 1; }
            if len(aline) > plen {
                if aline[0..plen] == prefix {
                    let hname = aline[plen..len(aline)];
                    let route = __lookup_handler_route(wires, hname);
                    let mut entry = hname;
                    if len(route) > 0 {
                        entry = hname + " (" + route + ")";
                    }
                    if afirst {
                        handlers_with_routes = entry;
                        afirst = false;
                    } else {
                        handlers_with_routes = handlers_with_routes + ", " + entry;
                    }
                }
            }
        }
        op_summary = op_summary + to_string(n_handlers) + " HTTP handler(s): "
            + handlers_with_routes;
    }
    if n_spawns > 0 {
        if len(op_summary) > 0 { op_summary = op_summary + "; "; }
        // Format spawns with target + defining-file lookup.
        // Each OP_SPAWN tag is "kind:target" where target is
        // empty for anonymous spawns. Named spawns get their
        // defining file looked up in fn_defs.
        let mut spawns_pretty = "";
        let prefix = "OP_SPAWN:";
        let plen = len(prefix);
        let mut sfrom = 0;
        let stotal = len(acc);
        let mut sfirst = true;
        while sfrom < stotal {
            let srest = acc[sfrom..stotal];
            let snl = std::str::index_of(srest, "\n");
            let mut sline = "";
            if snl < 0 { sline = srest; sfrom = stotal; }
            else { sline = srest[0..snl]; sfrom = sfrom + snl + 1; }
            if len(sline) > plen {
                if sline[0..plen] == prefix {
                    let body = sline[plen..len(sline)];
                    // body is "kind:target".
                    let cidx = std::str::index_of(body, ":");
                    let mut kind = body;
                    let mut target = "";
                    if cidx >= 0 {
                        kind = body[0..cidx];
                        target = body[cidx+1..len(body)];
                    }
                    let mut entry = kind;
                    if kind == "anonymous" {
                        entry = "anonymous func";
                    } else {
                        if len(target) > 0 {
                            let target_file = __lookup_fn_file(fn_defs, target);
                            if len(target_file) > 0 {
                                entry = target + " (" + target_file + ")";
                            } else {
                                entry = target + " (?)";
                            }
                        } else {
                            entry = "named (?)";
                        }
                    }
                    if sfirst { spawns_pretty = entry; sfirst = false; }
                    else { spawns_pretty = spawns_pretty + ", " + entry; }
                }
            }
        }
        op_summary = op_summary + to_string(n_spawns) + " concurrent spawn(s): "
            + spawns_pretty;
    }
    if n_loops > 0 {
        if len(op_summary) > 0 { op_summary = op_summary + "; "; }
        op_summary = op_summary + "long-running for-loop";
    }

    // Domain summary lines (one per type with motion).
    let mut dom_summary = "";
    let mut tfrom = 0;
    let total = len(acc);
    let prefix = "TYPE:";
    let plen = len(prefix);
    while tfrom < total {
        let rest = acc[tfrom..total];
        let nl = std::str::index_of(rest, "\n");
        let mut line = "";
        if nl < 0 { line = rest; tfrom = total; }
        else { line = rest[0..nl]; tfrom = tfrom + nl + 1; }
        if len(line) > plen {
            if line[0..plen] == prefix {
                let tname = line[plen..len(line)];
                let motion = r.name_to_motion(tname);
                if len(dom_summary) > 0 { dom_summary = dom_summary + "\n                "; }
                dom_summary = dom_summary + tname + " → " + motion;
            }
        }
    }

    let shape = __infer_locus_shape(has_main, has_init, n_handlers,
                                     n_spawns, n_loops, n_types, n_imports);

    // Verdict marker.
    let mut marker = "[structural]";
    if verdict == "locus" { marker = "[locus]"; }
    else if verdict == "type_or_fn" { marker = "[type_or_fn]"; }

    let header = "+-- " + proposed + "  (" + name + ")  "
        + marker + "  agreement=" + to_string(agreement) + "/3 ----";

    let mut out = header + "\n";
    out = out + "  package       " + pkg + "\n";
    out = out + __indent_block("operational ", op_summary);
    out = out + __indent_block("harmonic    ", imports);
    out = out + __indent_block("domain      ", dom_summary);
    out = out + "  aperio shape  " + shape + "\n";
    out = out + "\n";
    return out;
}

// ---- Recognition narrative. ----
//
// Top-level paragraph that frames what the user/agent just saw.
// Templated on summary counts; v0 is intentionally simple — the
// narrative's job is to land the recognition, not to be exhaustive.
fn __render_narrative(n_loci: Int, n_type_or_fn: Int, n_struct: Int,
                      n_unknowns: Int) -> String {
    let mut out = "";
    out = out + "Recognition\n";
    out = out + "-----------\n";
    out = out + "\n";
    if n_loci == 0 {
        out = out + "No clear lotus shape detected. The codebase may be too\n";
        out = out + "small (single-file utility) or have signals only in one\n";
        out = out + "tower at a time. Cross-tower agreement is what surfaces\n";
        out = out + "loci; without it, every file lands as type/fn or\n";
        out = out + "structural support.\n";
        return out;
    }
    out = out + to_string(n_loci) + " file(s) exhibit lotus shape "
        + "(at least 2 of 3 tower roles populated).\n";
    if n_type_or_fn > 0 {
        out = out + to_string(n_type_or_fn) + " file(s) are single-tower — "
            + "likely emit as types, free fns, or structural\n"
            + "support around the loci.\n";
    }
    if n_struct > 0 {
        out = out + to_string(n_struct) + " file(s) carry no tower signal "
            + "(empty / pure boilerplate).\n";
    }
    out = out + "\n";
    out = out + "What this means: your codebase already projects through\n";
    out = out + "three lenses cleanly. Each detected locus owns a region\n";
    out = out + "(memory), has a lifecycle (operational), participates in\n";
    out = out + "dependency contracts (harmonic), and names its concepts\n";
    out = out + "(domain). The lotus shape isn't being imposed — it's\n";
    out = out + "being recognized.\n";
    if n_unknowns > 0 {
        out = out + "\n";
        out = out + to_string(n_unknowns) + " unknown morpheme(s) flagged for\n";
        out = out + "agent review (see section above). For each, an LLM agent\n";
        out = out + "should read the source file, classify the noun per\n";
        out = out + "notes/onboarding-shape-rules.md (Agent / Entity / Shape),\n";
        out = out + "and propose a motion-form or reclassify as a type.\n";
    }
    return out;
}

// ---- Unknowns section (agent-actionable). ----

fn __render_unknowns(unknowns: String) -> String {
    if len(unknowns) == 0 { return ""; }
    let mut out = "";
    out = out + "Unknowns flagged for agent review\n";
    out = out + "----------------------------------\n";
    out = out + "\n";
    out = out + unknowns;
    out = out + "Per notes/onboarding-shape-rules.md:\n";
    out = out + "  - Agent noun  (-er/-or/-ar suffix on verb stem):\n";
    out = out + "                strip suffix, add -ing.\n";
    out = out + "  - Entity noun (named for the flow it enables):\n";
    out = out + "                propose verb the tool serves.\n";
    out = out + "  - Shape noun  (pure data, no flow):\n";
    out = out + "                no motion form; emit as `type`,\n";
    out = out + "                not `locus`.\n";
    out = out + "\n";
    return out;
}

// Render one binary's full recognition report. `binary_dir` is
// the directory holding the binary's main.go; `r` is a Morpheme
// rewriter pre-loaded with any per-repo overrides; `flavor` is
// the language flavor for parsing. Called once per discovered
// binary by the orchestrating __drive.
fn __drive_one_binary(binary_dir: String, flavor: String,
                      r: std::lang::Morpheme) {
    let lang = std::lang::Lang { flavor: flavor };

    let entries = std::io::fs::list_dir(binary_dir);
    let total = len(entries);
    if total == 0 {
        println("(empty or unreadable dir: ", binary_dir, ")");
        return;
    }

    println("------------------------------------------------------------");
    println("  Binary: ", binary_dir);
    println("------------------------------------------------------------");
    println("");

    // Module resolution. Walk up from `dir` looking for
    // go.mod, then extract its `module X` line. Used to:
    //   - Classify imports as "local" vs stdlib/external.
    //   - Resolve local-import paths to sibling dirs so the
    //     cross-dir walk can pull their FN_DEFs into the
    //     outward-tower lookup table. Without this step, every
    //     callee that crosses a package boundary degrades to
    //     {external} regardless of whether it's reachable from
    //     the codebase itself.
    let mut module_name = "";
    let mut module_root = "";
    let mod_root_candidate = __find_module_root(binary_dir);
    if len(mod_root_candidate) > 0 {
        module_root = mod_root_candidate;
        let mod_text = std::io::fs::read_file(module_root + "/go.mod");
        module_name = __extract_module_name(mod_text);
    }

    // First pass: walk the user-given dir and every local-
    // import dir into one combined tagged-string accumulator,
    // then route the combined output into the per-tag buckets
    // the renderers expect.
    //
    // Local-import walks contribute FN_DEF, IMP_FILE, WIRE, and
    // CALL rows (so the outward tower can resolve cross-dir
    // callees) but their OP_MAIN rows are ignored — main_file
    // means "the entrypoint binary this onboard run is
    // describing," which is always rooted in the user-given
    // dir. A sibling pkg with its own main is a different
    // binary's entrypoint and not relevant to this run.
    //
    // std::source::Walk drives the per-file iteration; the
    // __cross_dir_callback callback emits the tagged rows the
    // towers consume. Sibling-dir walks go through
    // __prefix_stamp so files resolve as "cmd/setup.go" vs.
    // user-dir's bare "setup.go".
    let w = std::source::Walk {
        flavor: flavor,
        on_file: __cross_dir_callback,
    };
    let user_walk = w.each_file(binary_dir);
    let mut combined = user_walk;
    if len(module_name) > 0 {
        let local_imps = __collect_local_imports(user_walk, module_name);
        let it_li = std::iter::Lines { };
        let mut lfrom = 0;
        while lfrom >= 0 {
            let imp = it_li.line_at(local_imps, lfrom);
            lfrom = it_li.next_idx(local_imps, lfrom);
            if len(imp) == 0 { continue; }
            let sib_dir = __local_import_to_dir(module_root,
                                                module_name, imp);
            // file_prefix mirrors the import path under the
            // module name, with a trailing slash so files stamp
            // as "<sibling-relpath>/<filename>".
            let ml = len(module_name);
            let mut sib_prefix = "";
            if len(imp) > ml { sib_prefix = imp[ml+1..len(imp)] + "/"; }
            let sib_walk = w.each_file(sib_dir);
            combined = combined + __prefix_stamp(sib_walk, sib_prefix);
        }
    }

    // Route combined into the per-tag aggregates that the
    // renderers consume. OP_MAIN file is recorded only from the
    // user-dir walk (which preserves the bare filename, no
    // sibling prefix), so the first OP_MAIN row with no slash
    // wins. Sibling-dir OP_MAINs have a "/"-bearing file stamp
    // and are ignored for entrypoint-mode purposes.
    let mut wires = "";
    let mut fn_defs = "";
    let mut calls = "";
    let mut main_file = "";
    let mut imports_by_file = "";
    let it_c = std::iter::Lines { };
    let mut cfrom = 0;
    while cfrom >= 0 {
        let sline = it_c.line_at(combined, cfrom);
        cfrom = it_c.next_idx(combined, cfrom);
        if len(sline) == 0 { continue; }
        if len(sline) > 5 {
            if sline[0..5] == "WIRE:" {
                wires = wires + sline + "\n";
                continue;
            }
            if sline[0..5] == "CALL:" {
                calls = calls + sline + "\n";
                continue;
            }
        }
        if len(sline) > 7 {
            if sline[0..7] == "FN_DEF:" {
                fn_defs = fn_defs + sline + "\n";
                continue;
            }
        }
        if len(sline) > 9 {
            if sline[0..9] == "IMP_FILE:" {
                imports_by_file = imports_by_file + sline + "\n";
                continue;
            }
        }
        if len(sline) >= 8 {
            if sline[0..8] == "OP_MAIN:" {
                let body = sline[8..len(sline)];
                if std::str::index_of(body, "/") < 0 {
                    if len(main_file) == 0 { main_file = body; }
                }
            }
        }
    }

    let mut all_files_section = "";
    let mut unknowns_section = "";
    let mut n_loci = 0;
    let mut n_type_or_fn = 0;
    let mut n_struct = 0;
    let mut n_unknowns = 0;
    let mut from = 0;
    while from < total {
        let rest = entries[from..total];
        let nl = std::str::index_of(rest, "\n");
        let mut name = "";
        if nl < 0 { name = rest; from = total; }
        else { name = rest[0..nl]; from = from + nl + 1; }
        if len(name) > 0 {
            if std::io::fs::extension(name) == ".go" {
                let block = __render_per_file(lang, r, binary_dir, name, wires, fn_defs);
                if len(block) > 0 {
                    all_files_section = all_files_section + block;
                    if std::str::index_of(block, "[locus]") >= 0 {
                        n_loci = n_loci + 1;
                    } else if std::str::index_of(block, "[type_or_fn]") >= 0 {
                        n_type_or_fn = n_type_or_fn + 1;
                    } else {
                        n_struct = n_struct + 1;
                    }
                    // Walk again for unknowns. Cheap, and avoids
                    // threading another return value through render.
                    let path = binary_dir + "/" + name;
                    let src = std::io::fs::read_file(path);
                    if len(src) > 0 {
                        let tree = lang.parse(src);
                        if tree != 0 {
                            let root = std::ts::root_node(tree);
                            let walk = __unified_walk(lang, root, false, "");
                            let prefix = "TYPE:";
                            let plen = len(prefix);
                            let mut wfrom = 0;
                            let wtotal = len(walk);
                            while wfrom < wtotal {
                                let wrest = walk[wfrom..wtotal];
                                let wnl = std::str::index_of(wrest, "\n");
                                let mut wline = "";
                                if wnl < 0 { wline = wrest; wfrom = wtotal; }
                                else { wline = wrest[0..wnl]; wfrom = wfrom + wnl + 1; }
                                if len(wline) > plen {
                                    if wline[0..plen] == prefix {
                                        let tname = wline[plen..len(wline)];
                                        let motion = r.name_to_motion(tname);
                                        if std::str::index_of(motion, "<unknown:") >= 0 {
                                            n_unknowns = n_unknowns + 1;
                                            unknowns_section = unknowns_section
                                                + "  * " + name + " : " + tname
                                                + "\n      static rewriter: "
                                                + motion + "\n      action: open "
                                                + name + " and apply shape rules.\n";
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    print(all_files_section);
    print(__render_outward_tower(calls, fn_defs, main_file, r));
    print(__render_inward_tower(calls, fn_defs, wires,
                                imports_by_file, main_file,
                                module_name));
    print(__render_unknowns(unknowns_section));
    print(__render_narrative(n_loci, n_type_or_fn, n_struct, n_unknowns));
}

// ---- Multi-binary entrypoint discovery. ----
//
// Real codebases ship more than one binary from one repo. The
// Cobra-CLI shape (`cmd/<name>/main.go`) is the canonical
// example, but vendored monorepos and nested-binary repos
// follow the same shape. Ferryman discovers every directory
// under the repo root that contains a `main.go`, then renders
// one binary report per discovery.
//
// The recursion is shallow and conservative: bounded depth,
// known noise dirs skipped, non-dir entries detected via the
// "list_dir returns empty for files" idiom (since std::io::fs
// doesn't ship an is_dir primitive at v0 and we don't need
// one for this specific question).

// True for dirs that shouldn't be traversed during entrypoint
// discovery. Conservatively excludes vendored deps, build
// artifacts, and VCS metadata. Source-tree convention only;
// not enforced by the type system.
fn __should_skip_dir(name: String) -> Bool {
    if name == "vendor" { return true; }
    if name == "node_modules" { return true; }
    if name == ".git" { return true; }
    if name == ".github" { return true; }
    if name == "target" { return true; }
    if name == "dist" { return true; }
    if name == "build" { return true; }
    if name == ".aperio" { return true; }
    if len(name) > 0 {
        if name[0..1] == "." { return true; }
    }
    return false;
}

// Recursively find every directory under `root` (inclusive)
// that contains a `main.go`. Returns a newline-separated
// String of absolute-style paths. Depth-capped at 6 levels
// to bound work on huge trees; binaries deeper than that are
// rare and can be addressed by pointing ferryman lower.
fn __find_main_dirs(root: String, depth: Int, max_depth: Int) -> String {
    // Direct-hit: this very directory has a main.go.
    if std::io::fs::file_exists(root + "/main.go") {
        return root + "\n";
    }
    if depth >= max_depth { return ""; }
    let entries = std::io::fs::list_dir(root);
    if len(entries) == 0 { return ""; }
    let it = std::iter::Lines { };
    let mut out = "";
    let mut from = 0;
    while from >= 0 {
        let name = it.line_at(entries, from);
        from = it.next_idx(entries, from);
        if len(name) == 0 { continue; }
        if __should_skip_dir(name) { continue; }
        let sub_path = root + "/" + name;
        // list_dir returns "" for regular files. Non-empty
        // means it's a non-empty directory; recurse.
        // Empty dirs are indistinguishable from files at this
        // surface, but they hold no main.go either way.
        let sub_entries = std::io::fs::list_dir(sub_path);
        if len(sub_entries) == 0 { continue; }
        out = out + __find_main_dirs(sub_path, depth + 1, max_depth);
    }
    return out;
}

// Count non-empty newline-separated entries in `s`. Used for
// the binaries-discovered count printed in the repo header.
fn __count_lines(s: String) -> Int {
    let it = std::iter::Lines { };
    let mut from = 0;
    let mut n = 0;
    while from >= 0 {
        let line = it.line_at(s, from);
        from = it.next_idx(s, from);
        if len(line) == 0 { continue; }
        n = n + 1;
    }
    return n;
}

// Strip the leading `prefix + "/"` from `path` for shorter
// display in headers. If `path` doesn't start with the prefix,
// returns it unchanged.
fn __relativize(path: String, prefix: String) -> String {
    let pl = len(prefix);
    let l = len(path);
    if l <= pl { return path; }
    if path[0..pl] != prefix { return path; }
    if path[pl..pl+1] != "/" { return path; }
    return path[pl+1..l];
}

// Top-level orchestrator. Discovers binaries, loads repo-root
// overrides once, dispatches per-binary rendering.
fn __drive(cfg: FerrymanConfig) {
    // Per-codebase overrides: an agent driving the session
    // resolves <unknown:X> markers and writes its decisions to
    // `<repo>/.aperio-overrides`. We pick that up once at the
    // repo root and apply it to every discovered binary's
    // morpheme rewriter. Per-binary overrides aren't supported
    // at v0 — they'd diverge vocabulary per-binary, which is
    // rarely what you want for a single repo.
    let overrides_path = cfg.dir + "/.aperio-overrides";
    let mut overrides_text = "";
    if std::io::fs::file_exists(overrides_path) {
        overrides_text = std::io::fs::read_file(overrides_path);
    }
    let r = std::lang::Morpheme {
        flavor: cfg.flavor,
        overrides: overrides_text,
    };

    let mains = __find_main_dirs(cfg.dir, 0, 6);
    let n_binaries = __count_lines(mains);

    println("============================================================");
    println("  Aperio recognition: ", cfg.dir);
    println("  flavor: ", cfg.flavor);
    if len(overrides_text) > 0 {
        println("  overrides: .aperio-overrides loaded (", len(overrides_text), " bytes)");
    }
    if n_binaries == 0 {
        println("  binaries: none discovered (no main.go found under tree)");
        println("============================================================");
        println("");
        // Fall back to the legacy single-dir behavior: render
        // the user-given dir as-is. Towers will be empty (no
        // main()), but the per-file boxes still surface useful
        // signal. This is what onboard did before multi-binary
        // support landed; preserving it keeps non-Go and shared-
        // code-dir inputs working.
        __drive_one_binary(cfg.dir, cfg.flavor, r);
        return;
    }
    println("  binaries: ", n_binaries, " discovered");
    println("============================================================");
    println("");

    let it = std::iter::Lines { };
    let mut from = 0;
    let mut idx = 0;
    while from >= 0 {
        let bin_dir = it.line_at(mains, from);
        from = it.next_idx(mains, from);
        if len(bin_dir) == 0 { continue; }
        idx = idx + 1;
        let rel = __relativize(bin_dir, cfg.dir);
        println("");
        println(">>> Binary ", idx, "/", n_binaries, ": ", rel);
        println("");
        __drive_one_binary(bin_dir, cfg.flavor, r);
    }
}

locus FerrymanL {
    params {
        config: FerrymanConfig = FerrymanConfig {
            dir: "apps/operational-graph/fixture",
            flavor: "go",
        };
    }
    run() {
        __drive(self.config);
    }
}

// The three-step ritual: instantiate Resolver, collapse
// FerrymanConfig, hand to FerrymanL. Resolver layers default →
// env (APERIO_DIR / APERIO_FLAVOR) → CLI (argv[1] / argv[2]).
fn main() {
    let r = std::cli::Resolver {
        env_prefix: "APERIO_",
        argv_keys:  "dir\nflavor\n",
    };
    let cfg = FerrymanConfig {
        dir:    r.get("dir",    "apps/operational-graph/fixture"),
        flavor: r.get("flavor", "go"),
    };
    FerrymanL { config: cfg };
}
