// 50-mode-defaults — m54: default param values on locus mode
// methods.
//
// m32 shipped defaults on free fns; m34 extended them to locus
// `fn` methods called via `self.method(...)`. Modes
// (`bulk` / `harmonic` / `resolution`) had been left out at
// codegen-declare time with a "not yet lowered" rejection. The
// CHECKPOINT polish entry blamed F.10 for a "tighter param
// surface", but F.10 only governs mode-keyword-as-member-name
// parsing — not param shape. Modes ARE just locus methods named
// after their kind, and `lower_self_method_call` already routes
// Fn and Mode through the same default-fill-in path. The only
// thing m54 changes is lifting the codegen-declare rejection
// (replaced with the same suffix-only ordering check the locus
// `fn` path already uses).
//
// What this example exercises:
//
//   mode bulk(scale: Int = 10) -> Int — caller can omit `scale`,
//   the call site fills the default at call-site lowering time
//   (same flow as free-fn defaults: literal defaults reduce to
//   constants, expressions evaluate at the call site in caller
//   scope).
//
// Bound checks:
//
//   - Calling `self.bulk()` with zero args fills `scale = 10`
//     from the default; total computed against the default.
//   - Calling `self.bulk(2)` overrides; total computed against
//     the override.
//   - Calling `self.harmonic()` with zero args (harmonic has no
//     params) still works — establishing that adding defaults
//     to ONE mode doesn't break the others.

locus AggregatorL {
    params {
        items: [Int; 4] = [1, 2, 3, 4];
    }

    mode bulk(scale: Int = 10) -> Int {
        let mut sum: Int = 0;
        for i in 0..4 {
            sum = sum + self.items[i] * scale;
        }
        return sum;
    }

    mode harmonic() -> Int {
        let mut count: Int = 0;
        for _ in 0..4 {
            count = count + 1;
        }
        return count;
    }

    run() {
        println("bulk default:    ", self.bulk());
        println("bulk overridden: ", self.bulk(2));
        println("harmonic:        ", self.harmonic());
    }
}

fn main() {
    AggregatorL { };
}
