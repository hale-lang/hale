// fitter-applier-demo — single-process orchestration of the
// fitter-applier-pair pipeline.
//
// Same shared types and same locus shapes as
// `examples/fitter-applier-pair/`, but bundled into one binary so the
// pipeline runs end-to-end under `hale run`. In production
// each locus would be its own binary, communicating across the
// bus over NATS / UDP multicast / shared memory; here they all
// subscribe to the same in-process router.
//
// Pipeline:
//   ObservationSourceL — publishes 5 synthetic Observation
//                        events at birth
//   FitterL            — subscribes Observation; publishes
//                        Kernel after 3 validations
//   ApplierL           — subscribes Observation + Kernel;
//                        publishes Action
//   ActionLogL         — subscribes Action; prints
//
// Order of instantiation: subscribers first (logger, applier,
// fitter), then source last so its birth() publishes into
// fully-wired transports.

type Observation {
    value_low: Decimal;
    value_high: Decimal;
    timestamp: Time;
}

type Kernel {
    scale: Decimal;
    valid_after: Time;
    perspective_id: Int;
}

type Action {
    kind: String;
    magnitude: Decimal;
    quantity: Decimal;
    action_id: Int;
}

locus ActionLogL {
    bus {
        subscribe "fitter.action" as on_action of type Action;
    }

    fn on_action(a: Action) {
        println("action #", a.action_id, ": ", a.kind, " ", a.quantity, " @ ", a.magnitude);
    }
}

locus ApplierL {
    params {
        current_kernel: Kernel = Kernel {
            scale: 1.0d,
            valid_after: `2026-01-01T00:00:00Z`,
            perspective_id: 0,
        };
        next_action_id: Int = 1;
    }

    bus {
        subscribe "fitter.observation" as on_observation of type Observation;
        subscribe "fitter.kernel"      as on_kernel      of type Kernel;
        publish   "fitter.action"                        of type Action;
    }

    fn on_observation(obs: Observation) {
        let a = Action {
            kind: "primary",
            magnitude: obs.value_low * self.current_kernel.scale,
            quantity: 1.0d,
            action_id: self.next_action_id,
        };
        self.next_action_id = self.next_action_id + 1;
        "fitter.action" <- a;
    }

    fn on_kernel(k: Kernel) {
        // Hot-load: replace the current kernel atomically. In
        // production this is the perspective hot-load
        // mechanism (F.7) — torn-read-free.
        self.current_kernel = k;
        println("applier: hot-loaded kernel id=", k.perspective_id);
    }
}

locus FitterL {
    params {
        latest_kernel: Kernel = Kernel {
            scale: 1.0d,
            valid_after: `2026-01-01T00:00:00Z`,
            perspective_id: 0,
        };
        validation_count: Int = 0;
        published_count: Int = 0;
    }

    bus {
        subscribe "fitter.observation" as on_observation of type Observation;
        publish   "fitter.kernel"                        of type Kernel;
    }

    fn on_observation(obs: Observation) {
        // Refit the kernel from the new observation in place — bump
        // perspective_id, leave the scale at 1.0d. Mutating the fields
        // avoids re-allocating the whole struct every message, so the
        // kernel state doesn't accumulate in the locus arena.
        self.latest_kernel.valid_after = obs.timestamp;
        self.latest_kernel.perspective_id = self.latest_kernel.perspective_id + 1;
        self.validation_count = self.validation_count + 1;

        // Multi-perspective stability commit-rule: ship only
        // after >=3 independent validations.
        if self.validation_count >= 3 {
            "fitter.kernel" <- self.latest_kernel;
            self.published_count = self.published_count + 1;
        }
    }

    // Audit invariant: the publish stream tracks validations
    // with a fixed offset (the first ≥3 validations are
    // absorbed before the first publish). Tolerance of 1
    // for pre-threshold transients. Fires at program-end
    // dissolve via the F.4 cascade.
    closure publish_keeps_pace {
        self.published_count ~~ self.validation_count - 2 within 1;
    }
}

locus ObservationSourceL {
    bus {
        publish "fitter.observation" of type Observation;
    }

    birth() {
        // Five synthetic observations — enough to cross the
        // fitter's validation_count >= 3 threshold and observe
        // a kernel hot-load mid-stream.
        "fitter.observation" <- Observation {
            value_low: 100.00d,
            value_high: 100.05d,
            timestamp: `2026-05-08T09:30:00Z`,
        };
        "fitter.observation" <- Observation {
            value_low: 100.10d,
            value_high: 100.15d,
            timestamp: `2026-05-08T09:30:01Z`,
        };
        "fitter.observation" <- Observation {
            value_low: 100.20d,
            value_high: 100.25d,
            timestamp: `2026-05-08T09:30:02Z`,
        };
        "fitter.observation" <- Observation {
            value_low: 100.30d,
            value_high: 100.35d,
            timestamp: `2026-05-08T09:30:03Z`,
        };
        "fitter.observation" <- Observation {
            value_low: 100.40d,
            value_high: 100.45d,
            timestamp: `2026-05-08T09:30:04Z`,
        };
    }
}

fn main() {
    // Subscribers first — they must be registered before the
    // source's birth() publishes (v0 router has no history;
    // late subscribers don't see past events).
    ActionLogL { };
    ApplierL { };
    FitterL { };
    ObservationSourceL { };
}
