// Per-directory seed model. Every .hl file in this directory
// contributes to one bundle; top-level decls in any file are
// visible to every other file.
//
// Build with the directory as the target:
//   hale build examples/multi-file-seed
//   ./examples/multi-file-seed/multi-file-seed
//
// File order is alphabetical: greet.hl then main.hl. Order
// doesn't matter for resolution — the bundle flattens all
// top-level decls into one shared scope.

locus AppL {
    params {
        who: String = "world";
    }
    run() {
        let phrase = greeting(self.who);
        say(phrase);
    }
}

fn main() {
    AppL { };
}
