// 07-control-flow — `if` / `while` / `break` / `continue` via the
// codegen path.
//
// Folds the hand-unrolled counter from 06-mutable-counter into a
// loop that walks 1..=10, skips n==7 (`continue`), exits early at
// n==9 (`break`), and sums the kept values. Demonstrates basic-
// block management, nested control flow, and the loop stack used
// to thread break/continue targets.
//
// Sum trace: 1+2+3+4+5+6 + 8 = 29 (7 skipped, 9 breaks before add).

fn main() {
    let mut n = 0;
    let mut sum = 0;
    while n < 10 {
        n = n + 1;
        if n == 7 {
            continue;
        }
        if n == 9 {
            break;
        }
        sum = sum + n;
    }
    println("sum=", sum, " stopped at n=", n);
}
