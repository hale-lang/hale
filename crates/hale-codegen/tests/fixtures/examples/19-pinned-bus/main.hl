// 19-pinned-bus — cross-thread bus: cooperative publisher,
// pinned subscriber.
//
// The pinned subscriber gets its own per-locus mailbox: a
// LOCK-FREE bounded MPSC ring (the canonical Vyukov queue),
// plus a mutex + condvar retained ONLY for the consumer's
// blocking park and cross-thread backpressure — never per
// message. When the cooperative publisher's `<-` runs, the
// bus dispatch path notices the subscriber's registration
// carries a mailbox pointer, copies the typed payload INLINE
// into a ring slot via a single lock-free enqueue, then
// signals the condvar ONLY if the consumer is parked. The
// pinned thread's main loop is in lotus_mailbox_drain_one;
// under load it is busy draining (never parked, no mutex on
// the hot path); when idle it parks and the post's
// parked-check wakes it. It pops the cell, copies the
// payload from the inline slot into ITS OWN arena, and
// invokes the handler.
//
// Per The Design / lotus, this is the canonical "any →
// pinned" bus path: publisher and subscriber sit in
// different layers of the lotus, the substrate cost lives
// at the layer boundary (the mailbox lock + the inline
// payload's two memcpy's), and each arena stays single-
// threaded territory. Bimodality holds: cooperative on one
// side, pinned on the other, no third "shared-arena" mode.
//
// Coordinated shutdown: at scope exit (main returning),
// the deferred-dissolve flush signals shutdown on the
// pinned subscriber's mailbox; the pinned thread observes
// drain_one == 0, breaks its loop, runs drain/dissolve, and
// exits. Main joins the pthread before destroying the
// pinned arena.

// F.31 (2026-05-23): pinned placement moved from a per-locus
// annotation to a `placement { }` block on `main locus`.

type Tick {
    n: Int;
    label: String;
}

locus PinnedSubscriber {
    bus {
        subscribe "tick" as on_tick of type Tick;
    }

    birth() {
        println("pinned subscriber: birth on pinned thread");
    }

    fn on_tick(t: Tick) {
        println("pinned subscriber: got tick #", t.n, " (", t.label, ")");
    }

    dissolve() {
        println("pinned subscriber: dissolve on pinned thread");
    }
}

locus Publisher {
    bus {
        publish "tick" of type Tick;
    }

    birth() {
        "tick" <- Tick { n: 1, label: "first" };
        "tick" <- Tick { n: 2, label: "second" };
        "tick" <- Tick { n: 3, label: "third" };
    }
}

main locus PinnedBusApp {
    params {
        sub: PinnedSubscriber = PinnedSubscriber { };
        pub: Publisher        = Publisher        { };
    }
    placement {
        sub: pinned;
    }
    run() {
        // Give the pinned thread a moment to drain the mailbox
        // BEFORE main returns (the deferred-dissolve flush
        // will signal shutdown). Without this, the shutdown
        // signal can race past unprocessed cells (we still
        // drain them — pending cells flush before the loop
        // returns 0 — but a tiny sleep here makes the output
        // ordering deterministic vs main's println).
        std::time::sleep(20ms);

        println("main: returning; pinned subscriber will drain + dissolve");
    }
}

fn main() {
    PinnedBusApp { };
}
