// 03-closure-test — collapse vs explosion.
//
// A locus declares two values and asserts they should match.
// On dissolution, the closure is evaluated:
//   - pass  -> collapse: clean dissolve, parent sees normal
//              child-dissolution event, no output.
//   - fail  -> explosion: locus dissolves with audit failure;
//              v0 surfaces the ClosureViolation report on
//              stderr. F.9's full design also bubbles to the
//              parent's on_failure handler — that path lands
//              when failure routing is wired in.

locus CheckerL {
    params {
        x: Int = 5;
        y: Int = 5;
    }

    closure xy_match {
        self.x ~~ self.y within 0;
        // Default epoch: dissolve. Closure evaluates as the
        // locus dissolves; if it fails, the locus is exploded.
    }
}

fn main() {
    println("--- pass case (5 ~~ 5 within 0): expect silent collapse ---");
    CheckerL { x: 5, y: 5 };

    println("--- fail case (5 ~~ 7 within 0): expect ClosureViolation ---");
    CheckerL { x: 5, y: 7 };

    println("--- after both dissolves ---");
}
